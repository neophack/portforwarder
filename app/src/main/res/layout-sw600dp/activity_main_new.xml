<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_ipados_window"
    android:orientation="horizontal"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="4dp"
            android:paddingBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="端口转发"
                    android:textColor="@color/ipados_title"
                    android:textSize="34sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="iPadOS 控制面板"
                    android:textColor="@color/ipados_subtitle"
                    android:textSize="13sp" />
            </LinearLayout>

            <Button
                android:id="@+id/btn_settings"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_ipados_action"
                android:minWidth="0dp"
                android:paddingHorizontal="16dp"
                android:text="设置"
                android:textColor="@color/ipados_title"
                android:textSize="13sp" />
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/ipados_card"
            app:cardCornerRadius="22dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="服务状态"
                    android:textColor="@color/ipados_subtitle"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_service_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="未启动"
                    android:textColor="@color/ipados_title"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_last_update"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="刚刚更新"
                    android:textColor="@color/ipados_subtitle"
                    android:textSize="12sp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="10dp"
                    android:background="@color/ipados_divider" />

                <TextView
                    android:id="@+id/tv_config_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="配置 0"
                    android:textColor="@color/ipados_title"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_active_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="活动 0"
                    android:textColor="@color/ipados_subtitle"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_device_ip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="IP: 0.0.0.0"
                    android:textColor="@color/ipados_subtitle"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="开机自启"
                        android:textColor="@color/ipados_subtitle"
                        android:textSize="12sp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/sw_auto_start_service"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:trackTint="@color/ios_switch_on" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="8dp"
            android:paddingStart="6dp"
            android:text="快捷操作"
            android:textColor="@color/ipados_subtitle"
            android:textSize="12sp" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_start_all"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_ipados_action"
                    android:minWidth="0dp"
                    android:paddingHorizontal="14dp"
                    android:text="全部启动"
                    android:textColor="@color/ios_green"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btn_stop_all_new"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_ipados_action"
                    android:minWidth="0dp"
                    android:paddingHorizontal="14dp"
                    android:text="全部停止"
                    android:textColor="@color/ios_red"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btn_add_config"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_ipados_action"
                    android:minWidth="0dp"
                    android:paddingHorizontal="14dp"
                    android:text="添加配置"
                    android:textColor="@color/ipados_title"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btn_smart_config"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_ipados_action"
                    android:minWidth="0dp"
                    android:paddingHorizontal="14dp"
                    android:text="智能配网"
                    android:textColor="@color/ipados_title"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btn_refresh"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_ipados_action"
                    android:minWidth="0dp"
                    android:paddingHorizontal="14dp"
                    android:text="刷新状态"
                    android:textColor="@color/ipados_title"
                    android:textSize="13sp" />

                <Button
                    android:id="@+id/btn_refresh_ip"
                    style="?android:attr/borderlessButtonStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_ipados_action"
                    android:minWidth="0dp"
                    android:paddingHorizontal="14dp"
                    android:text="刷新 IP"
                    android:textColor="@color/ipados_title"
                    android:textSize="13sp" />
            </LinearLayout>
        </HorizontalScrollView>
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:paddingStart="6dp"
            android:text="转发列表"
            android:textColor="@color/ipados_subtitle"
            android:textSize="12sp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            app:cardBackgroundColor="@color/ipados_card"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_forward_configs"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:padding="8dp" />
        </androidx.cardview.widget.CardView>
    </LinearLayout>

</LinearLayout>