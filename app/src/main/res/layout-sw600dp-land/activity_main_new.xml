<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:padding="20dp">

    <!-- 左侧控制面板 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1.5"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="@drawable/card_background"
        android:layout_marginEnd="20dp">

        <!-- 标题栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="端口转发器"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/black" />

                <!-- 服务状态指示器 -->
                <TextView
                    android:id="@+id/tv_service_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="服务未启动"
                    android:textSize="14sp"
                    android:padding="10dp"
                    android:background="@drawable/service_status_background"
                    android:textColor="@android:color/white" />

            </LinearLayout>

            <!-- 设备IP显示 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="本机IP: "
                    android:textSize="18sp"
                    android:textColor="@android:color/darker_gray" />

                <TextView
                    android:id="@+id/tv_device_ip"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="获取中..."
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/holo_blue_dark" />

                <Button
                    android:id="@+id/btn_refresh_ip"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="刷新IP"
                    android:textSize="14sp"
                    android:background="@drawable/button_refresh"
                    android:textColor="@android:color/white"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- 全局控制按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="全局控制"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"
                android:textColor="@android:color/black" />

            <Button
                android:id="@+id/btn_start_all"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="一键启动"
                android:textSize="18sp"
                android:background="@color/button_start"
                android:textColor="@android:color/white"
                android:padding="16dp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_stop_all_new"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="全部停止"
                android:textSize="18sp"
                android:background="@color/button_stop"
                android:textColor="@android:color/white"
                android:padding="16dp"
                android:layout_marginBottom="12dp" />

            <Button
                android:id="@+id/btn_add_config"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="添加配置"
                android:textSize="18sp"
                android:background="@color/button_add"
                android:textColor="@android:color/white"
                android:padding="16dp" />

        </LinearLayout>

        <!-- 设置选项 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/settings_background"
            android:padding="20dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="设置选项"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="16dp"
                android:textColor="@android:color/black" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="开机启动服务"
                    android:textSize="18sp" />

                <Switch
                    android:id="@+id/sw_auto_start_service"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <Button
                    android:id="@+id/btn_smart_config"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="配网"
                    android:textSize="16sp"
                    android:background="@drawable/button_smart_config"
                    android:textColor="@android:color/white"
                    android:padding="16dp"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btn_settings"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="设置"
                    android:textSize="16sp"
                    android:background="@drawable/button_settings"
                    android:textColor="@android:color/white"
                    android:padding="16dp"
                    android:layout_marginStart="4dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- 底部状态栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/status_bar_background"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="活动转发:"
                android:textSize="16sp"
                android:textColor="@android:color/darker_gray" />

            <TextView
                android:id="@+id/tv_active_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/holo_green_dark"
                android:layout_marginStart="8dp"
                android:layout_marginEnd="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="最后更新:"
                android:textSize="16sp"
                android:textColor="@android:color/darker_gray" />

            <TextView
                android:id="@+id/tv_last_update"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="--:--:--"
                android:textSize="16sp"
                android:textColor="@android:color/darker_gray"
                android:layout_marginStart="8dp" />

            <Button
                android:id="@+id/btn_refresh"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="刷新"
                android:textSize="14sp"
                android:background="@drawable/button_refresh"
                android:textColor="@android:color/white"
                android:paddingStart="20dp"
                android:paddingEnd="20dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- 右侧转发配置列表 -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="2.5"
        android:orientation="vertical"
        android:background="@drawable/card_background"
        android:padding="12dp">

        <!-- 转发配置列表标题 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp"
            android:padding="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="转发配置列表"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@android:color/black" />

            <TextView
                android:id="@+id/tv_config_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0 个配置"
                android:textSize="16sp"
                android:textColor="@android:color/darker_gray" />

        </LinearLayout>

        <!-- 转发配置列表 -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_forward_configs"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scrollbars="vertical"
            android:padding="8dp" />

    </LinearLayout>

</LinearLayout> 