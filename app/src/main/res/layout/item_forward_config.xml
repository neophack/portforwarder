<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/ios_card"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:orientation="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_config_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="配置名称"
                        android:textColor="@color/ios_title"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_config_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/status_badge"
                        android:paddingHorizontal="6dp"
                        android:paddingVertical="2dp"
                        android:text="状态"
                        android:textColor="@android:color/white"
                        android:textSize="10sp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_config_rule"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:fontFamily="sans-serif-medium"
                    android:text="TCP 8080 -> 192.168.1.100:80"
                    android:textColor="@color/ios_subtitle"
                    android:textSize="14sp" />
            </LinearLayout>

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/sw_enabled"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:thumbTint="@color/ios_card"
                app:trackTint="@color/ios_switch_on" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_start_config"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_weight="1"
                android:background="@drawable/button_start_small"
                android:text="启动"
                android:textColor="@color/ios_green"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_stop_config"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/button_stop_small"
                android:text="停止"
                android:textColor="@color/ios_red"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_edit_config"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/button_edit_small"
                android:text="编辑"
                android:textColor="@color/ios_blue"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_delete_config"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="0dp"
                android:layout_height="32dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:background="@drawable/button_delete_small"
                android:text="删除"
                android:textColor="@color/ios_red"
                android:textSize="13sp" />
        </LinearLayout>

    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_marginStart="16dp"
        android:background="@color/ios_divider" />
</LinearLayout>
