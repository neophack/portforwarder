<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <!-- 配置输入界面 -->
    <LinearLayout
        android:id="@+id/content_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- WiFi信息显示 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ESP32 SmartConfig 配网"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tv_current_ssid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="当前WiFi: 未知"
            android:textSize="16sp"
            android:textColor="@android:color/holo_blue_dark"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_current_bssid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MAC地址: 未知"
            android:textSize="14sp"
            android:textColor="@android:color/darker_gray"
            android:layout_marginBottom="16dp" />

        <!-- WiFi密码输入 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="WiFi密码:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_wifi_password"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="请输入WiFi密码"
            android:text="12345678"
            android:inputType="text"
            android:layout_marginBottom="16dp" />

        <!-- 设备数量输入 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="设备数量:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_device_count"
            android:layout_width="120dp"
            android:layout_height="wrap_content"
            android:hint="1"
            android:text="1"
            android:inputType="number"
            android:layout_marginBottom="16dp" />

        <!-- 说明文字 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="注意事项:\n1. 确保ESP32设备处于配网模式\n2. 设备和手机连接同一WiFi网络\n3. 配网过程可能需要1-2分钟"
            android:textSize="14sp"
            android:textColor="@android:color/darker_gray"
            android:layout_marginBottom="24dp" />

        <!-- 按钮组 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="取消"
                android:background="@drawable/button_cancel"
                android:textColor="@android:color/white"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btn_start_config"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="开始配网"
                android:background="@drawable/button_start"
                android:textColor="@android:color/white"
                android:layout_marginStart="8dp" />

        </LinearLayout>

    </LinearLayout>

    <!-- 配网进度界面 -->
    <LinearLayout
        android:id="@+id/progress_view"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ESP32 SmartConfig 配网"
            android:textSize="18sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <ProgressBar
            android:id="@+id/progress_bar"
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/tv_progress_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="正在配网，请稍候..."
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginBottom="16dp" />

        <!-- 配网结果显示 -->
        <TextView
            android:id="@+id/tv_config_result"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginBottom="24dp"
            android:visibility="gone" />

        <Button
            android:id="@+id/btn_cancel_config"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="取消配网"
            android:background="@drawable/button_cancel"
            android:textColor="@android:color/white"
            android:paddingStart="24dp"
            android:paddingEnd="24dp" />

    </LinearLayout>

</FrameLayout> 