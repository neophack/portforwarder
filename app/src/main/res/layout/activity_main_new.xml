<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_ipados_window"
    android:orientation="vertical"
    android:paddingHorizontal="16dp"
    android:paddingTop="20dp"
    android:paddingBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="4dp"
        android:paddingBottom="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="端口转发"
                android:textColor="@color/ipados_title"
                android:textSize="30sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="iPadOS 风格控制台"
                android:textColor="@color/ipados_subtitle"
                android:textSize="13sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btn_settings"
            style="?android:attr/borderlessButtonStyle"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:background="@drawable/bg_ipados_action"
            android:minWidth="0dp"
            android:paddingHorizontal="16dp"
            android:text="设置"
            android:textColor="@color/ipados_title"
            android:textSize="13sp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="118dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            app:cardBackgroundColor="@color/ipados_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="服务状态"
                    android:textColor="@color/ipados_subtitle"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tv_service_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="未启动"
                    android:textColor="@color/ipados_title"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_last_update"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="刚刚更新"
                    android:textColor="@color/ipados_subtitle"
                    android:textSize="12sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="118dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            app:cardBackgroundColor="@color/ipados_card"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:id="@+id/tv_config_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="配置 0"
                    android:textColor="@color/ipados_title"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_active_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="活动 0"
                    android:textColor="@color/ipados_subtitle"
                    android:textSize="13sp" />

                <TextView
                    android:id="@+id/tv_device_ip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="IP: 0.0.0.0"
                    android:textColor="@color/ipados_subtitle"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="开机自启"
                        android:textColor="@color/ipados_subtitle"
                        android:textSize="12sp" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/sw_auto_start_service"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:trackTint="@color/ios_switch_on" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_start_all"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:background="@drawable/bg_ipados_action"
                android:minWidth="0dp"
                android:paddingHorizontal="16dp"
                android:text="全部启动"
                android:textColor="@color/ios_green"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_stop_all_new"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_ipados_action"
                android:minWidth="0dp"
                android:paddingHorizontal="16dp"
                android:text="全部停止"
                android:textColor="@color/ios_red"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_add_config"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_ipados_action"
                android:minWidth="0dp"
                android:paddingHorizontal="16dp"
                android:text="添加配置"
                android:textColor="@color/ipados_title"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_smart_config"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_ipados_action"
                android:minWidth="0dp"
                android:paddingHorizontal="16dp"
                android:text="智能配网"
                android:textColor="@color/ipados_title"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_refresh"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_ipados_action"
                android:minWidth="0dp"
                android:paddingHorizontal="16dp"
                android:text="刷新状态"
                android:textColor="@color/ipados_title"
                android:textSize="13sp" />

            <Button
                android:id="@+id/btn_refresh_ip"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="38dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_ipados_action"
                android:minWidth="0dp"
                android:paddingHorizontal="16dp"
                android:text="刷新 IP"
                android:textColor="@color/ipados_title"
                android:textSize="13sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="8dp"
        android:paddingStart="6dp"
        android:text="转发列表"
        android:textColor="@color/ipados_subtitle"
        android:textSize="12sp" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        app:cardBackgroundColor="@color/ipados_card"
        app:cardCornerRadius="22dp"
        app:cardElevation="0dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_forward_configs"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:padding="6dp" />
    </androidx.cardview.widget.CardView>

</LinearLayout>
