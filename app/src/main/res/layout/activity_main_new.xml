<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ios_bg"
    android:orientation="vertical">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="36dp"
        android:paddingBottom="8dp"
        android:text="碯口转发"
        android:textColor="@color/ios_title"
        android:textSize="32sp"
        android:textStyle="bold" />

    <!-- 状态与开机自启 -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="@color/ios_card"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 全局服务状仁 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="戍务亞怂"
                    android:textColor="@color/ios_title"
                    android:textSize="17sp" />
                    
                <Space android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"/>
                
                <TextView
                    android:id="@+id/tv_service_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="巜停正"
                    android:textColor="@color/ios_subtitle"
                    android:textSize="17sp" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="@color/ios_divider" android:layout_marginStart="16dp"/>

            <!-- 开机自启 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="开机自启"
                    android:textColor="@color/ios_title"
                    android:textSize="17sp" />
                    
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/sw_auto_start_service"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:thumbTint="@color/ios_card"
                    app:trackTint="@color/ios_switch_on" />
            </LinearLayout>
            
            <View android:layout_width="match_parent" android:layout_height="0.5dp" android:background="@color/ios_divider" android:layout_marginStart="16dp"/>

            <!-- 统计俣恭 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">
                
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    
                    <TextView
                        android:id="@+id/tv_config_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="配置数mn:n 0"
                        android:textColor="@color/ios_subtitle"
                        android:textSize="13sp" />
                        
                    <TextView
                        android:id="@+id/tv_active_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="胘鹜鸸 0"
                        android:textColor="@color/ios_subtitle"
                        android:textSize="13sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="end">
                    
                    <TextView
                        android:id="@+id/tv_device_ip"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="IP: 127.0.0.1"
                        android:textColor="@color/ios_subtitle"
                        android:textSize="13sp" />
                        
                    <TextView
                        android:id="@+id/tv_last_update"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="刚刚"
                        android:textColor="@color/ios_subtitle"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- 操作楞钮区 -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btn_start_all"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/button_start_small"
                android:text=" 全启 "
                android:textColor="@color/ios_green"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_stop_all_new"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/button_stop_small"
                android:text=" 全停 "
                android:textColor="@color/ios_red"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_add_config"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/button_edit_small"
                android:text=" 添加 "
                android:textColor="@color/ios_blue"
                android:textSize="14sp" />
                
            <Button
                android:id="@+id/btn_smart_config"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/button_edit_small"
                android:text=" 智跽配置 "
                android:textColor="@color/ios_blue"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_refresh"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/button_edit_small"
                android:text=" 刷新配置 "
                android:textColor="@color/ios_blue"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btn_refresh_ip"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/button_edit_small"
                android:text=" 刷新IP "
                android:textColor="@color/ios_blue"
                android:textSize="14sp" />
                
            <Button
                android:id="@+id/btn_settings"
                style="?android:attr/borderlessButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/button_edit_small"
                android:text=" settings "
                android:textColor="@color/ios_subtitle"
                android:textSize="14sp" />
        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="32dp"
        android:paddingBottom="6dp"
        android:text="胆陇列表管"
        android:textColor="@color/ios_subtitle"
        android:textSize="13sp" />

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="16dp"
        app:cardBackgroundColor="@color/ios_card"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_forward_configs"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"/>

    </androidx.cardview.widget.CardView>

</LinearLayout>
