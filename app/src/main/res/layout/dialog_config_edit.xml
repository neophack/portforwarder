<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 配置名称 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="配置名称:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_config_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="输入配置名称"
            android:inputType="text"
            android:layout_marginBottom="16dp" />

        <!-- 协议选择 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="协议类型:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <RadioGroup
            android:id="@+id/rg_protocol_edit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <RadioButton
                android:id="@+id/rb_tcp_edit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TCP"
                android:checked="true"
                android:layout_marginEnd="24dp" />

            <RadioButton
                android:id="@+id/rb_udp_edit"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="UDP" />

        </RadioGroup>

        <!-- 监听端口 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="监听端口:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_listen_port_edit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="请输入监听端口 (1-65535)"
            android:inputType="number"
            android:layout_marginBottom="16dp" />

        <!-- 目标主机 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="目标主机:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <EditText
                android:id="@+id/et_target_host_edit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="请输入目标主机IP或域名"
                android:inputType="textUri"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btn_scan_lan"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="扫描"
                android:textSize="12sp"
                android:background="@drawable/button_refresh"
                android:textColor="@android:color/white"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:minWidth="0dp" />

        </LinearLayout>

        <!-- 目标端口 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="目标端口:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_target_port_edit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="请输入目标端口 (1-65535)"
            android:inputType="number"
            android:layout_marginBottom="16dp" />

        <!-- 高级选项 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="高级选项:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/advanced_options_background"
            android:padding="12dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="启用配置"
                    android:textSize="14sp" />

                <Switch
                    android:id="@+id/sw_config_enabled"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true" />

            </LinearLayout>

<!--            <LinearLayout-->
<!--                android:layout_width="match_parent"-->
<!--                android:layout_height="wrap_content"-->
<!--                android:orientation="horizontal"-->
<!--                android:gravity="center_vertical">-->

<!--                <TextView-->
<!--                    android:layout_width="0dp"-->
<!--                    android:layout_height="wrap_content"-->
<!--                    android:layout_weight="1"-->
<!--                    android:text="开机自动启动"-->
<!--                    android:textSize="14sp" />-->

<!--                <Switch-->
<!--                    android:id="@+id/sw_config_auto_start"-->
<!--                    android:layout_width="wrap_content"-->
<!--                    android:layout_height="wrap_content" />-->

<!--            </LinearLayout>-->

        </LinearLayout>

        <!-- 按钮组 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="24dp">

            <Button
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="取消"
                android:background="@drawable/button_cancel"
                android:textColor="@android:color/white"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btn_save"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="保存"
                android:background="@drawable/button_save"
                android:textColor="@android:color/white"
                android:layout_marginStart="8dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView> 