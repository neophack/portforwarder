<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="270"
                android:endColor="#EEF3F8"
                android:startColor="#F8FBFF" />
        </shape>
    </item>
    <item android:bottom="-120dp" android:left="-120dp">
        <shape android:shape="oval">
            <solid android:color="#1A89A8D8" />
            <size android:width="320dp" android:height="320dp" />
        </shape>
    </item>
    <item android:right="-140dp" android:top="-120dp">
        <shape android:shape="oval">
            <solid android:color="#1AC7D6EA" />
            <size android:width="360dp" android:height="360dp" />
        </shape>
    </item>
</layer-list>
